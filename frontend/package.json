    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "axe-core": "4.12.1",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.20",
      "sharp": "0.35.3"
    }
