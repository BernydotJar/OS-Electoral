# Deterministic local-development defaults. These credentials are not for shared environments.
COMPOSE_PROJECT_NAME=campaignos

# CampaignOS API
CAMPAIGNOS_ENVIRONMENT=development
CAMPAIGNOS_LOG_LEVEL=INFO
CAMPAIGNOS_EXPOSE_API_DOCS=true
CAMPAIGNOS_API_PORT=8000
CAMPAIGNOS_DATABASE_URL=postgresql+psycopg://campaignos_app:campaignos_app_dev_only@postgres:5432/campaignos
CAMPAIGNOS_SMTP_FROM=campaignos@localhost

# PostgreSQL
POSTGRES_DB=campaignos
POSTGRES_USER=campaignos_admin
POSTGRES_PASSWORD=campaignos_admin_dev_only
CAMPAIGNOS_DATABASE_USER=campaignos_app
CAMPAIGNOS_DATABASE_PASSWORD=campaignos_app_dev_only
POSTGRES_PORT=5432

# Hermetic S3Mock storage. It accepts dummy credentials and is local-test only.
S3MOCK_ACCESS_KEY=campaignos_local_only
S3MOCK_SECRET_KEY=campaignos_local_secret
S3MOCK_BUCKET=campaignos-local
S3MOCK_PORT=9090

# Mailpit
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
MAILPIT_MAX_MESSAGES=5000

# Optional development OIDC configuration. All three values are required together.
# CAMPAIGNOS_OIDC_ISSUER=https://identity.example.test/
# CAMPAIGNOS_OIDC_AUDIENCE=campaignos-local
# CAMPAIGNOS_OIDC_JWKS_URL=https://identity.example.test/.well-known/jwks.json
