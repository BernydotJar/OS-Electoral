# Local functional journey only. Never use these values in shared environments.
COMPOSE_PROJECT_NAME=campaignos-functional

CAMPAIGNOS_ENVIRONMENT=development
CAMPAIGNOS_LOG_LEVEL=INFO
CAMPAIGNOS_EXPOSE_API_DOCS=true
CAMPAIGNOS_API_PORT=8000
CAMPAIGNOS_DATABASE_URL=postgresql+psycopg://campaignos_app:campaignos_app_dev_only@postgres:5432/campaignos
CAMPAIGNOS_DEVELOPMENT_ACCESS_TOKEN=campaignos-local-development-token
CAMPAIGNOS_DEVELOPMENT_PRINCIPAL_SUBJECT=local-operator
CAMPAIGNOS_DEVELOPMENT_PRINCIPAL_DISPLAY_NAME="Operador local"
CAMPAIGNOS_DEVELOPMENT_PRINCIPAL_EMAIL=operator@localhost
CAMPAIGNOS_SMTP_FROM=campaignos@localhost

POSTGRES_DB=campaignos
POSTGRES_USER=campaignos_admin
POSTGRES_PASSWORD=campaignos_admin_dev_only
CAMPAIGNOS_DATABASE_USER=campaignos_app
CAMPAIGNOS_DATABASE_PASSWORD=campaignos_app_dev_only
POSTGRES_PORT=5432

S3MOCK_ACCESS_KEY=campaignos_local_only
S3MOCK_SECRET_KEY=campaignos_local_secret
S3MOCK_BUCKET=campaignos-local
S3MOCK_PORT=9090

MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
MAILPIT_MAX_MESSAGES=5000

CAMPAIGNOS_FRONTEND_MODE=live
CAMPAIGNOS_FRONTEND_ENVIRONMENT=development
CAMPAIGNOS_API_BASE_URL=http://127.0.0.1:8000
CAMPAIGNOS_FRONTEND_DEVELOPMENT_TOKEN=campaignos-local-development-token
CAMPAIGNOS_FRONTEND_DEVELOPMENT_TENANT_ID=11111111-1111-4111-8111-111111111111
NEXT_TELEMETRY_DISABLED=1
