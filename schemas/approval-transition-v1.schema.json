{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://os-electoral.local/schemas/approval-transition-v1.schema.json",
  "title":"Approval Transition Command v1",
  "type":"object","additionalProperties":false,
  "required":["schema_version","transition_id","request_ref","action","actor_type","actor_id","role","selected_option_ref","occurred_at","reason","tenant_id","campaign_id","workspace_id"],
  "properties":{
    "schema_version":{"const":"1.0"},
    "transition_id":{"$ref":"#/$defs/id"},"request_ref":{"$ref":"#/$defs/id"},
    "action":{"enum":["APPROVE","REJECT","REVOKE","EXPIRE"]},
    "actor_type":{"enum":["HUMAN","SYSTEM"]},"actor_id":{"$ref":"#/$defs/id"},"role":{"type":"string","minLength":1},
    "selected_option_ref":{"oneOf":[{"$ref":"#/$defs/id"},{"type":"null"}]},
    "occurred_at":{"type":["string","null"]},"reason":{"type":"string"},
    "tenant_id":{"$ref":"#/$defs/id"},"campaign_id":{"$ref":"#/$defs/id"},"workspace_id":{"$ref":"#/$defs/id"}
  },
  "$defs":{"id":{"type":"string","pattern":"^[a-z][a-z0-9_-]*:[A-Za-z0-9][A-Za-z0-9._-]*$"}}
}
